rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザードキュメント: 本人のみ読み書き可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ペアドキュメント
    match /pairs/{pairId} {
      // 招待コード照合・ペア一覧: 認証済みなら読み取り可
      allow read: if request.auth != null;

      // master側: 新規ペア作成（自分がpartnersに含まれること）
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.partners;

      // master exclusive unpair (v6.1): master_uidのみfull update権限
      // member joinは member_uid未設定時のみ許可（active変更は不可）
      // Note: resource.data.get('member_uid', null) は存在しないフィールドをnullとして扱う
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.master_uid
        || resource.data.get('member_uid', null) == null
      );

      allow delete: if false;

      // アイテムサブコレクション: 親pairのpartners[]に含まれるユーザーのみ
      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners;

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners;
      }
    }
  }
}
