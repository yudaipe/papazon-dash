rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザードキュメント: 本人のみ読み書き可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ペアドキュメント (v6.2: cmd_667 厳格化)
    match /pairs/{pairId} {
      // list: 招待コード照合 (joinByCode whereEqualTo クエリ) のために認証済みユーザーに許可
      // get: 自分がpartnersに含まれる場合のみ取得可
      allow list: if request.auth != null;
      allow get: if request.auth != null
        && request.auth.uid in resource.data.partners;

      // master側: 新規ペア作成（自分がpartnersに含まれること）
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.partners;

      // master exclusive update (v6.4): master_uidのみfull update権限
      // member join (Branch B): joinByCode()が書き込む3フィールドのみ許可
      //   - member_uid: 自分のUIDのみ設定可
      //   - joined_at: serverTimestamp (実装: joinByCode() line 337)
      //   - partners: arrayUnion(自uid) — 既存partners保持+自uid追加+size+1厳格検証
      //   - master_uid / active / inviteCode は不変
      allow update: if request.auth != null && (
        // Branch A: master exclusive
        request.auth.uid == resource.data.master_uid
        || (
          // Branch B: member join — strictly constrained field diff
          resource.data.get('member_uid', null) == null
          && request.resource.data.member_uid == request.auth.uid
          && request.resource.data.master_uid == resource.data.master_uid
          && request.resource.data.active == resource.data.active
          && request.resource.data.get('inviteCode', null) == resource.data.get('inviteCode', null)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['member_uid', 'joined_at', 'partners'])
          && request.resource.data.partners.hasAll(resource.data.partners)
          && request.auth.uid in request.resource.data.partners
          && request.resource.data.partners.size() == resource.data.partners.size() + 1
        )
      );

      // 削除: 明示禁止（cascade削除はCloud Functions onPairDeactivated が担当）
      allow delete: if false;

      // アイテムサブコレクション: partnersに含まれるユーザーかつペアがactive=trueの場合のみ書込可
      match /items/{itemId} {
        // 読み取り: partnersに含まれるユーザーのみ
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners;

        // 作成・更新: partnersかつペアがactive=true（deactivated pairへの書込拒否）
        allow create, update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners
          && get(/databases/$(database)/documents/pairs/$(pairId)).data.active == true;

        // 削除: 明示禁止（cascade削除はCloud Functions が担当）
        allow delete: if false;
      }
    }
  }
}
