rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザードキュメント: 本人のみ読み書き可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ペアドキュメント (v6.2: cmd_667 厳格化)
    match /pairs/{pairId} {
      // list: 招待コード照合 (joinByCode whereEqualTo クエリ) のために認証済みユーザーに許可
      // get: 自分がpartnersに含まれる場合のみ取得可
      allow list: if request.auth != null;
      allow get: if request.auth != null
        && request.auth.uid in resource.data.partners;

      // master側: 新規ペア作成（自分がpartnersに含まれること）
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.partners;

      // master exclusive update (v6.1): master_uidのみfull update権限
      // member joinは member_uid未設定時のみ許可（active変更は不可）
      // Note: resource.data.get('member_uid', null) は存在しないフィールドをnullとして扱う
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.master_uid
        || resource.data.get('member_uid', null) == null
      );

      // 削除: 明示禁止（cascade削除はCloud Functions onPairDeactivated が担当）
      allow delete: if false;

      // アイテムサブコレクション: partnersに含まれるユーザーかつペアがactive=trueの場合のみ書込可
      match /items/{itemId} {
        // 読み取り: partnersに含まれるユーザーのみ
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners;

        // 作成・更新: partnersかつペアがactive=true（deactivated pairへの書込拒否）
        allow create, update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.partners
          && get(/databases/$(database)/documents/pairs/$(pairId)).data.active == true;

        // 削除: 明示禁止（cascade削除はCloud Functions が担当）
        allow delete: if false;
      }
    }
  }
}
